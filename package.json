{
  "name": "quickiptvplayer",
  "private": true,
  "version": "0.0.0",
  "description": "Desktop IPTV player with playlist management, search, compact player mode, and Windows builds.",
  "author": "Pappuraj Bhottacharjee <info@pappuraj.com> (https://pappuraj.com)",
  "license": "MIT",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "concurrently -k \"npm:dev\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "dist:win": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& npm run build && electron-builder --win nsis --publish never",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "hls.js": "^1.6.13",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.quickiptvplayer.desktop",
    "productName": "QuickIPTV Player",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
